# .env.example — template of every env var this agent reads.
#
# This file is COMMITTED. The real .env is gitignored (see .gitignore).
# Copy this file to .env for local dev, fill in real values, never commit:
#
#   cp .env.example .env
#   docker run --env-file .env -v hermes-data:/data -p 8080:8080 hermes-coala
#
# On Railway, set these in the Project → Variables panel instead. The
# bootstrap will WARN (not crash) if no provider key is set, so the
# container boots even without secrets — useful for build verification.

# ── Admin dashboard (web login) ─────────────────────────────────────────────
# The admin server gates the web UI behind a cookie-auth login. Username
# defaults to "admin" if unset. If ADMIN_PASSWORD is unset, a random 16-char
# token is auto-generated on boot and printed to logs — fine for first deploy,
# set explicitly for anything you care about.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ── Required: at least one LLM provider key ─────────────────────────────────
# Match `provider.name` in hermes-config/hermes.toml. Default is "nous".

NOUS_API_KEY=
# OPENROUTER_API_KEY=sk-or-...
# OPENAI_API_KEY=sk-...

# ── Optional: grounding-action surfaces (MCP servers) ───────────────────────

# GitHub MCP is live by default in mcp.json. Without this token the github-*
# channels become unreachable but the agent stays up.
GITHUB_TOKEN=

# Railway MCP / programmatic Railway access (used by deploy-railway skill).
RAILWAY_TOKEN=

# Sentry MCP — for the debug-incident skill.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=

# Postgres / DB introspection (read-only URL recommended).
DATABASE_URL_READONLY=

# Brave Search (external web search beyond built-in tools).
BRAVE_API_KEY=

# ── Optional: messaging gateways ────────────────────────────────────────────

TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ── Optional: peer-agent platforms (stubbed in mcp.json) ────────────────────

PAPERCLIP_AI_TOKEN=
MULTICA_TOKEN=

# Generic agent-bridge adapter — see _generic_agent_bridge_example in mcp.json.
PEER_PLATFORM_URL=
PEER_PLATFORM_TOKEN=
PEER_AGENT_ID=

# ── Optional: OAuth-provider bootstrap ──────────────────────────────────────
# For providers that auth via OAuth device flow rather than a static API key
# (xAI Grok SuperGrok, Gemini CLI, Qwen OAuth, Claude Code). Set this to the
# JSON contents of a locally-generated ~/.hermes/auth.json; the bootstrap
# writes it to /data/hermes/auth.json on first boot. Subsequent token
# refreshes update the volume copy in place — you only set this once.
HERMES_AUTH_JSON_BOOTSTRAP=

# ── Optional: bootstrap behavior ────────────────────────────────────────────

# Set to 1 to overwrite agent-patched seed skills from /app on next boot.
# Useful when you've edited a seed skill in git and want it to win over
# any in-place patches the agent made on the volume.
HERMES_FORCE_RESEED=
