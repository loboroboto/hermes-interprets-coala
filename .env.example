# .env.example — template of every env var this agent reads.
#
# This file is COMMITTED. The real .env is gitignored (see .gitignore).
# Copy this file to .env for local dev, fill in real values, never commit:
#
#   cp .env.example .env
#   docker run --env-file .env -v hermes-data:/data -p 8080:8080 hermes-coala
#
# On Railway, set these in the Project → Variables panel instead. The
# bootstrap will WARN (not crash) if no provider key is set, so the
# container boots even without secrets — useful for build verification.

# ── Admin dashboard (web login) ─────────────────────────────────────────────
# The admin server gates the web UI behind a cookie-auth login. Username
# defaults to "admin" if unset. If ADMIN_PASSWORD is unset, a random 16-char
# token is auto-generated on boot and printed to logs — fine for first deploy,
# set explicitly for anything you care about.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ── Required: at least one LLM provider key ─────────────────────────────────
# Match `provider.name` in hermes-config/hermes.toml. Default is "openrouter"
# (one key serves the main agent AND every external fleet agent).

OPENROUTER_API_KEY=sk-or-...
# NOUS_API_KEY=            # if you set provider.name="nous" in hermes.toml
# OPENAI_API_KEY=sk-...

# ── Optional: grounding-action surfaces (MCP servers) ───────────────────────

# GitHub MCP is live by default in mcp.json. Without this token the github-*
# channels become unreachable but the agent stays up.
GITHUB_TOKEN=

# Railway MCP / programmatic Railway access (used by deploy-railway skill).
RAILWAY_TOKEN=

# Sentry MCP — for the debug-incident skill.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=

# Postgres / DB introspection (read-only URL recommended).
DATABASE_URL_READONLY=

# Brave Search (external web search beyond built-in tools).
BRAVE_API_KEY=

# ── Optional: messaging gateways ────────────────────────────────────────────

TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ── Optional: peer-agent platforms (stubbed in mcp.json) ────────────────────

PAPERCLIP_AI_TOKEN=
MULTICA_TOKEN=

# ── Optional: Fleet / hermes_remote runner (epic #8) ────────────────────────
# The paperclip-hermes-gateway runner (baked into the image) lets Paperclip
# spawn this hermes over Railway's private network. It only starts when
# RUNNER_AUTH_TOKEN is set; leave blank to keep it disabled. Paperclip's
# hermes_remote adapter must present the same token as a Bearer credential.
# Reachable privately at hermes-interprets-coala.railway.internal:8788 — no
# public domain needed.
RUNNER_AUTH_TOKEN=
# RUNNER_HOST=::        # bind addr; default :: (Railway private net is IPv6)
# RUNNER_PORT=8788      # default 8788
# Each fleet agent runs in its own CoALA home at /data/hermes/agents/<agentId>
# (set per agent via Paperclip adapterConfig.env.HERMES_HOME); the home is
# seeded from git-tracked config lazily on first /run (slice #11). HERMES_CMD
# defaults to the bundled /app/hermes-fleet-entry.sh wrapper — no need to set it.
#
# Onboarder/reconciler (slice #14 + #15): reconciles fleet/agents.yaml into Paperclip,
# onboarding the CEO agent onto hermes_remote. Set PAPERCLIP_ONBOARD to run the continuous
# reconcile loop on boot — it re-converges after a Paperclip adapter reset and onboards once
# the board adapter (#12) is installed, backing off (quietly) while it waits.
# PAPERCLIP_ONBOARD=1
# PAPERCLIP_CEO_KEY=         # CEO agent bearer key → written to /root/.pclip.key (chmod 600)
# PAPERCLIP_API_URL=http://paperclip.railway.internal:3100   # default; rarely overridden
# PAPERCLIP_ONBOARD_INTERVAL=300       # loop: seconds between reconcile passes (default 300)
# PAPERCLIP_ONBOARD_BACKOFF_MAX=3600   # loop: back-off cap (s) while waiting for the board adapter (default 3600)

# Generic agent-bridge adapter — see _generic_agent_bridge_example in mcp.json.
PEER_PLATFORM_URL=
PEER_PLATFORM_TOKEN=
PEER_AGENT_ID=

# ── Optional: OAuth-provider bootstrap ──────────────────────────────────────
# For providers that auth via OAuth device flow rather than a static API key
# (xAI Grok SuperGrok, Gemini CLI, Qwen OAuth, Claude Code). Set this to the
# JSON contents of a locally-generated ~/.hermes/auth.json; the bootstrap
# writes it to /data/hermes/auth.json on first boot. Subsequent token
# refreshes update the volume copy in place — you only set this once.
HERMES_AUTH_JSON_BOOTSTRAP=

# ── Optional: bootstrap behavior ────────────────────────────────────────────

# Set to 1 to overwrite agent-patched seed skills from /app on next boot.
# Useful when you've edited a seed skill in git and want it to win over
# any in-place patches the agent made on the volume.
HERMES_FORCE_RESEED=
